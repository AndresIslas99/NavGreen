<?xml version="1.0" encoding="UTF-8"?>
<!--
  TEMPLATE ONLY — NOT LOADED AT BOOT.

  agv_start.sh generates /tmp/agv_cyclonedds_runtime.xml dynamically at
  startup based on which network interfaces are actually UP. That runtime
  file is what CYCLONEDDS_URI points to in production. This file is kept
  only as a canonical reference and for manual debug invocations, e.g.:
      CYCLONEDDS_URI=file://...production.xml ros2 run <pkg> <node>

  If you edit this file expecting your changes to take effect at boot,
  they won't — either edit the generator block in agv_start.sh or
  override CYCLONEDDS_URI for your one-shot command.

  2026-04-13: l4tbr0 removed (USB host bridge, dev-only).
  2026-04-14: file repurposed as template; runtime XML generated by
  agv_start.sh because Cyclone treats every declared <NetworkInterface>
  as required — a rfkill-blocked or absent wlP1p1s0 would otherwise
  SIGABRT every ROS node at boot.
-->
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
  <Domain id="any">
    <General>
      <Interfaces>
        <!-- Ethernet: production site network for dashboard access -->
        <NetworkInterface name="eno1" priority="default" multicast="true" />
        <!-- WiFi: secondary path for tablet access in the field -->
        <NetworkInterface name="wlP1p1s0" priority="default" multicast="true" />
      </Interfaces>
      <AllowMulticast>true</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
      <FragmentSize>32768B</FragmentSize>
    </General>

    <Discovery>
      <LeaseDuration>30s</LeaseDuration>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>120</MaxAutoParticipantIndex>
      <Peers>
        <Peer address="localhost"/>
        <!-- 192.168.55.100 removed 2026-04-13 -->
      </Peers>
    </Discovery>

    <Internal>
      <!-- Sprint 1 Fase A2 (2026-04-24): SocketReceiveBufferSize 26MB→64MB
           and WhcHigh 500kB→4MB. ZED RGB HD frames are ~900 KB each; ZED +
           cuVSLAM + nvblox + image_server publishing simultaneously was
           overflowing the 500 kB writer history cache and causing silent
           drops. Keep this template in sync with the generator block in
           src/agv_bringup/scripts/agv_start.sh. -->
      <SocketReceiveBufferSize min="64MB" />
      <Watermarks>
        <WhcHigh>4MB</WhcHigh>
      </Watermarks>
    </Internal>

    <Tracing>
      <OutputFile>/tmp/cyclonedds.log</OutputFile>
      <Verbosity>warning</Verbosity>
    </Tracing>
  </Domain>
</CycloneDDS>
