<?xml version="1.0" encoding="UTF-8"?>
<!--
  CycloneDDS config for HIL cross-machine discovery.

  Before launching, set the PC's IP address in the Peers section below,
  then export this file:

    export CYCLONEDDS_URI=$(ros2 pkg prefix agv_bringup)/share/agv_bringup/config/cyclonedds_hil.xml

  The same ROS_DOMAIN_ID and RMW_IMPLEMENTATION must be used on both machines.
-->
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General>
      <Interfaces>
        <NetworkInterface name="wlP1p1s0" multicast="false"/>
      </Interfaces>
      <AllowMulticast>spdp</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
      <FragmentSize>32768B</FragmentSize>
    </General>
    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>120</MaxAutoParticipantIndex>
      <Peers>
        <Peer address="localhost"/>
        <!-- Set this to the PC running the simulation -->
        <Peer address="SIM-HOST-LAN-IP"/>
      </Peers>
    </Discovery>
    <Internal>
      <!-- Sprint 1 Fase A2 (2026-04-24): synced with production template;
           HIL exercises the same payload sizes as real and benefits from the
           same headroom. See src/agv_bringup/scripts/agv_start.sh comments. -->
      <SocketReceiveBufferSize min="64MB"/>
      <Watermarks>
        <WhcHigh>4MB</WhcHigh>
      </Watermarks>
    </Internal>
  </Domain>
</CycloneDDS>
