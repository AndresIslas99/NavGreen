<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>agv_rail_detector</name>
  <version>0.1.0</version>
  <description>ZED depth-based rail tube detection. Projects the ground-
  plane slice of the ZED depth image, runs RANSAC to find two parallel
  51 mm tubes 0.45 m apart, and publishes /agv/rail_detections so
  rail_driver can correct lateral drift in-rail without depending on
  pose/EKF alone. Phase 2 Stage J.</description>
  <maintainer email="andresislas2107@gmail.com">Andres Islas</maintainer>
  <license>MIT</license>
  <url type="website">https://orzatech.com</url>
  <url type="repository">https://github.com/AndresIslas99/NavGreen</url>
  <url type="bugtracker">https://github.com/AndresIslas99/NavGreen/issues</url>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>sensor_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>std_msgs</depend>

  <test_depend>ament_cmake_gtest</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
