<root main_tree_to_execute="WaypointPatrol">
  <BehaviorTree ID="WaypointPatrol">
    <Sequence>
      <SetBlackboard output_key="wp_index" value="0"/>
      <Repeat num_cycles="{num_waypoints}">
        <Sequence>
          <GetWaypointFromList waypoints="{waypoints}" index="{wp_index}" goal="{goal}"/>
          <Fallback>
            <NavigateToPose goal="{goal}" server_name="navigate_to_pose"/>
            <Sequence>
              <Wait msec="2000"/>
              <NavigateToPose goal="{goal}" server_name="navigate_to_pose"/>
            </Sequence>
          </Fallback>
          <IncrementCounter key="wp_index"/>
        </Sequence>
      </Repeat>
    </Sequence>
  </BehaviorTree>
</root>
