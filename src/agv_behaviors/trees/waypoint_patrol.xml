<root main_tree_to_execute="WaypointPatrol">
  <BehaviorTree ID="WaypointPatrol">
    <!--
      Patrol through a list of waypoints with recovery at each waypoint.
      Uses RecoveryNode per waypoint for robust handling.
    -->
    <Sequence>
      <SetBlackboard output_key="wp_index" value="0"/>
      <Repeat num_cycles="{num_waypoints}">
        <Sequence>
          <GetWaypointFromList waypoints="{waypoints}" index="{wp_index}" goal="{goal}"/>
          <RecoveryNode number_of_retries="3" name="WaypointRecovery">
            <PipelineSequence name="NavToWaypoint">
              <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
              <FollowPath path="{path}" controller_id="FollowPath"/>
            </PipelineSequence>
            <ReactiveFallback name="WaypointRecoveryActions">
              <GoalUpdated/>
              <RoundRobin>
                <Sequence name="ClearAndSpin">
                  <ClearEntireCostmap name="ClearLocal"
                    service_name="local_costmap/clear_entirely_local_costmap"/>
                  <Spin spin_dist="1.57"/>
                </Sequence>
                <Sequence name="BackupAndWait">
                  <BackUp backup_dist="0.3" backup_speed="0.1"/>
                  <Wait wait_duration="2"/>
                </Sequence>
              </RoundRobin>
            </ReactiveFallback>
          </RecoveryNode>
          <IncrementCounter key="wp_index"/>
        </Sequence>
      </Repeat>
    </Sequence>
  </BehaviorTree>
</root>
