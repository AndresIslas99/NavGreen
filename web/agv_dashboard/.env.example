# AGV Dashboard frontend — environment variables
#
# These are read at BUILD time by Vite (and at dev-server start). Copy this
# file to `.env.local` to override locally, or set the vars in your CI/build
# environment. All variables MUST be prefixed VITE_ to be exposed to the
# browser bundle (Vite security default).
#
# Sprint 1 Fase 1a: when the frontend is served from a host other than the
# backend (e.g., laptop running `caddy` while backend is on the Jetson),
# point these at the backend's reachable URL.

# Backend HTTP/REST + WebSocket origin. Empty = same-origin (backward compat,
# used when the backend serves the dashboard from /dashboard).
# Example: VITE_API_BASE=http://jetson.lan:8090
VITE_API_BASE=

# Fleet manager origin (port 8092 by default; port 8091 is the MJPEG
# image server). Empty = use VITE_API_BASE host with port 8092, falling
# back to the current page hostname.
# Example: VITE_FLEET_BASE=http://jetson.lan:8092
VITE_FLEET_BASE=

# Vite public path. Default '/dashboard/' matches backward-compat with the
# Express static mount. When serving via nginx/caddy at the root, set to '/'.
# Example: VITE_BASE_PATH=/
VITE_BASE_PATH=/dashboard/
